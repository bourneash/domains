# Parent .gitignore — applies to all repos rooted under /home/jesse/projects/domains/
# Individual repos also have their own .gitignore; this is belt-and-suspenders for secrets.

# Secrets
.env
.env.local
.env.*.local
*.pem
*.key
.cloudflared/

# Tooling artifacts at repo root
.playwright-mcp/
playwright-report/
test-results/
.claude/settings.local.json
node_modules/

# Stray screenshots dropped at root by browser sessions
/*.png
/*.jpg
/*.jpeg

# OS cruft
.DS_Store
Thumbs.db
