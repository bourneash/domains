    {
      "id": 7,
      "type": "table",
      "title": "Zones — Latest Snapshot",
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "cf-stats"
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawQueryText": "SELECT zone AS \"Zone\", pv_7d AS \"PV (7d)\", req_7d AS \"Requests (7d)\", uniq_7d AS \"Uniques (7d)\", ROUND(bytes_7d / 1000000.0, 1) AS \"MB (7d)\", threats_7d AS \"Threats (7d)\" FROM zones WHERE ts = (SELECT MAX(ts) FROM zones) AND req_7d > 0 ORDER BY pv_7d DESC",
          "format": "table",
          "queryType": "table"
        }
      ],
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "PV (7d)"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Threats (7d)"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 100
                    },
                    {
                      "color": "red",
                      "value": 500
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "displayName": "PV (7d)",
            "desc": true
          }
        ]
      }
    },
