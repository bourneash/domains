# Copy this file to .env and fill in your values.
# .env is gitignored — never commit the real file.

# Cloudflare — used by cf-stats, all deploy scripts, and domain ops
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Image APIs — used by content-writer roles for editorial images
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
UNSPLASH_APPLICATION_ID=
UNSPLASH_SECRET_KEY=

# Affiliate / partner APIs (add as you onboard new programs)
# AMAZON_ASSOCIATE_TAG=
# IMPACT_ACCOUNT_SID=
# IMPACT_AUTH_TOKEN=
