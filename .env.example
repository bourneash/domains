# /home/jesse/projects/domains/.env
# Shared credentials for all domain projects. gitignored at parent level.
# Copy to .env and fill in values. Source with: set -a; . ../.env; set +a

# === Cloudflare ===
# Create a custom token at: https://dash.cloudflare.com/profile/api-tokens
# Account scopes:
#   Workers Scripts:Edit, Workers Routes:Edit, Workers KV:Edit,
#   Workers R2:Edit, Pages:Edit, Account Analytics:Read
# Zone scopes (all zones from your account):
#   Zone:Read, DNS:Edit, Zone Settings:Edit, Cache Purge:Purge,
#   Page Rules:Edit, Transform Rules:Edit, Workers Routes:Edit,
#   Firewall Services:Edit
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=   # from the right sidebar of dash.cloudflare.com

# === GitHub ===
# Usually not needed — `gh` CLI handles auth. Only set if scripts need it.
# GITHUB_TOKEN=

# === Affiliate programs (add as signed up) ===
# AMAZON_ASSOCIATES_TAG=reviewtattoo-20
# (most affiliate programs don't have API tokens, only dashboards)
